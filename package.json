{
  "name": "lily-hopper",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,css}\" index.html \"*.{ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" index.html \"*.{ts,json,md}\""
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "prettier": "^3.6.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
